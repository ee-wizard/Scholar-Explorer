{
  "name": "retriever-querygen-v2",
  "tasks_dir": "integration/skillsbench/tasks",
  "output_dir": "outputs/experiments/latency/latency-retriever-querygen/",
  "corpus_path": "data/skills/",
  "max_tasks": 5,
  "cache_dir": "outputs/experiments/querygen-v2-cache/",
  "retrievers": [
    {
      "enabled": true,
      "retriever_type": "dense",
      "model_name": "BAAI/bge-base-en-v1.5",
      "query_prompt": "Represent this sentence for searching relevant passages: ",
      "index_dir": "outputs/indices/bge-base/",
      "top_k": 1000,
      "query_gen": {
        "enabled": true,
        "model": "gpt-4o-mini",
        "max_tokens": 200,
        "temperature": 0.0,
        "num_queries": [
          1,
          3,
          5
        ],
        "aggregation": [
          "rrf"
        ],
        "multi_query_prompt": "skill_flow/query_gen/instructions/multi_v2.txt"
      }
    }
  ]
}
