{
  "name": "reranker-comparison",
  "tasks_dir": "integration/skillsbench/tasks",
  "output_dir": "outputs/experiments/reranker-comparison/",
  "input_report_path": "outputs/experiments/retriever-union/bge-base-q5-union-tk200.json",
  "index_dir": "outputs/indices/bge-base/",
  "cache_dir": "outputs/experiments/querygen-v2-cache/",
  "rerankers": [
    {
      "enabled": true,
      "model_name": "cross-encoder/ms-marco-MiniLM-L-6-v2",
      "input_top_k": 1000,
      "batch_size": 128,
      "max_content_chars": 512,
      "query_gen": {
        "enabled": true,
        "model": "gpt-4o-mini",
        "max_tokens": 200,
        "temperature": 0.0,
        "num_queries": [1, 3, 5],
        "aggregation": ["max", "mean", "rrf"],
        "multi_query_prompt": "skill_flow/query_gen/instructions/multi_v2.txt"
      }
    },
    {
      "enabled": false,
      "model_name": "BAAI/bge-reranker-v2-m3",
      "input_top_k": 1000,
      "batch_size": 128,
      "max_content_chars": 512,
      "query_gen": {
        "enabled": true,
        "model": "gpt-4o-mini",
        "max_tokens": 200,
        "temperature": 0.0,
        "num_queries": [1, 3, 5],
        "aggregation": ["max", "mean", "rrf"],
        "multi_query_prompt": "skill_flow/query_gen/instructions/multi_v2.txt"
      }
    }
  ]
}
